# Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_WEBHOOK_SECRET=gere_com_openssl_rand_hex_32

# URL pública (ngrok ou domínio real — deve ser HTTPS)
WEBHOOK_BASE_URL=https://seu-dominio.com

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_URI=mongodb://admin:password@mongo:27017/chatbot?authSource=admin
MONGO_DB_NAME=chatbot

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=chatbot
POSTGRES_URI=postgresql://postgres:password@postgres:5432/chatbot

# Redis
REDIS_PASSWORD=password
REDIS_URI=redis://:password@redis:6379/0

# Rate limiting
RATE_LIMIT_MESSAGES=10
RATE_LIMIT_WINDOW=60

# Memória
MEMORY_WINDOW_SIZE=10
